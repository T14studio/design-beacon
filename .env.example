# Axis Consolidated Environment Variables
# ------------------------------------

# --- FRONTEND (React/Vite) ---
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui
VITE_AXIS_WEBHOOK_URL=https://seu-backend.onrender.com/axis/turn

# --- BACKEND (Python/FastAPI) ---
OPENAI_API_KEY=sua-chave-openai-aqui
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-service-key-aqui

# Rate Limiting — Chat/Axis
RATELIMIT_USER_MAX=5
RATELIMIT_USER_WINDOW=60
RATELIMIT_IP_MAX=15
RATELIMIT_IP_WINDOW=60

# Rate Limiting — Área do Cliente (CPF/CNPJ) — MAIS ESTRITO
# Limite padrão: 3 consultas por IP a cada 60 segundos
RATELIMIT_CONTRACTS_IP_MAX=3
RATELIMIT_CONTRACTS_IP_WINDOW=60

# --- CORS --- OBRIGATÓRIO EM PRODUÇÃO ---
# NUNCA deixar como * em produção — define o domínio exato do frontend
CORS_ORIGIN=https://seu-site.netlify.app

# ─────────────────────────────────────────────────────────────────────────────
# CANAL WHATSAPP VIA UAZAPI
# Para ativar: preencha as 4 variáveis abaixo e defina WHATSAPP_ENABLED=true
# O sistema permanece estável com WHATSAPP_ENABLED=false (padrão seguro)
# ─────────────────────────────────────────────────────────────────────────────

# Canal ativo (não alterar — suporte multi-provider futuro)
WHATSAPP_PROVIDER=uazapi

# Ativar/desativar o canal WhatsApp (false = desabilitado, seguro)
# Mude para true APENAS após preencher as 4 credenciais abaixo
WHATSAPP_ENABLED=false

# ─── PREENCHER COM CREDENCIAIS REAIS DA UAZAPI ────────────────────────────────
# URL base da sua instância Uazapi (ex: https://api.uazapi.com)
UAZAPI_BASE_URL=

# ID da instância WhatsApp na Uazapi
UAZAPI_INSTANCE_ID=

# Token de autenticação da API Uazapi
UAZAPI_TOKEN=

# Secret para validação de assinatura do webhook (escolha um valor forte e único)
UAZAPI_WEBHOOK_SECRET=

# ─── OPCIONAIS (complementares) ───────────────────────────────────────────────
# Código de país padrão (55 = Brasil)
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# Número comercial da empresa no WhatsApp (formato: 5511999999999)
WHATSAPP_COMMERCIAL_NUMBER=

# ─────────────────────────────────────────────────────────────────────────────
# BRAPI — Indicadores Econômicos (câmbio, SELIC, CDI, IPCA, TR)
# Fonte principal do dashboard financeiro. Substitui AwesomeAPI.
# Obtenha seu token em: https://brapi.dev/dashboard
# ─────────────────────────────────────────────────────────────────────────────

BRAPI_API_KEY=pSr3gnfgRdCnjMvbfRXpnu
BRAPI_BASE_URL=https://brapi.dev

# Configurações opcionais de resiliência (valores padrão abaixo)
BRAPI_TIMEOUT=8
BRAPI_RETRIES=2

# Template seguro — NUNCA commitar o arquivo .env com valores reais
