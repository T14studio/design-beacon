# Axis Project Configuration
# ----------------------------

# Backend OpenAI
OPENAI_API_KEY=your_key_here
# MODEL_NAME=gpt-4o

# Backend Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Security & Rate Limiting
# Max messages per browser/user ID in a window (seconds)
RATELIMIT_USER_MAX=5
RATELIMIT_USER_WINDOW=60
# Max messages per IP address in a window (seconds)
RATELIMIT_IP_MAX=15
RATELIMIT_IP_WINDOW=60

# CORS
# Specific domain for production (e.g., https://eticaimoveisbr.com.br)
CORS_ORIGIN=http://localhost:8080

# Frontend environment (if needed by build process)
# VITE_AXIS_WEBHOOK_URL=http://localhost:8000/axis/turn
