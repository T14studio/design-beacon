    {
      "parameters": {
        "jsCode": "const session = $('05D Merge Session').item.json;\nconst inbound = $('02 Code: Normaliza Payload').item.json.message;\nlet propertyStr = '';\nif ($('03 Supabase: Get Property').item.json && $('03 Supabase: Get Property').item.json[0]) {\n  const p = $('03 Supabase: Get Property').item.json[0];\n  propertyStr = `\\nIMÓVEL EM CONTEXTO: [${p.property_code}] ${p.title} (Bairro: ${p.neighborhood})`;\n}\nconst history = $input.all().map(i => `[${i.json.role.toUpperCase()}]: ${i.json.content}`).join('\\n');\n\nconst systemPrompt = `Você é a Axis, assistente virtual da Ética.\\nAtue com base na operação comercial e administrativa da imobiliária.\\n${propertyStr}\\n\\nHISTÓRICO:\\n${history}\\n\\nRETORNE APENAS UM JSON ESTRUTURADO:\\n{\\n  \"message_to_user\": \"string\",\\n  \"etapa_da_conversa\": \"string\",\\n  \"handoff_recomendado\": boolean,\\n  \"setor_destino\": \"string\",\\n  \"prioridade\": \"media\"\\n}`;\n\nreturn [{ json: { system_prompt: systemPrompt, user_message: inbound, session_id: session.session_id, property_id: session.property_id, loop_counter: session.loop_counter } }];"
      },
      "id": "node_08",
      "name": "08 Code: Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
