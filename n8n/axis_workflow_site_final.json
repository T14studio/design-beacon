        "jsCode": "try {\n  const rawContent = $input.first().json.choices[0].message.content;\n  const data = JSON.parse(rawContent);\n  return [{ json: data }];\n} catch (e) {\n  throw new Error('Falha ao processar resposta da OpenAI: ' + e.message);\n}"
      },
