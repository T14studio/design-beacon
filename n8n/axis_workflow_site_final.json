    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst message = (body.message || '').trim();\nconst phone = body.phone ? body.phone.replace(/\\D/g, '') : null;\nconst browser_user_id = body.browser_user_id || null;\nconst identifier = phone || browser_user_id;\nconst channel = body.channel || 'website';\n\nif (!identifier) throw new Error('Campo obrigatório ausente: phone ou browser_user_id');\nif (!message) throw new Error('Campo obrigatório ausente: message');\n\nlet propertyRef = body.property_code || null;\nif (!propertyRef) {\n  const codeMatch = message.match(/\\bREF[-_]?\\d+\\b/i);\n  const slugMatch = message.match(/imovel\\/([\\w-]+)/i);\n  propertyRef = codeMatch ? codeMatch[0].toUpperCase().replace(/[-_]/g, '') : (slugMatch ? slugMatch[1] : null);\n}\n\nreturn [{\n  json: {\n    identifier,\n    channel,\n    message,\n    property_ref: propertyRef,\n    name: body.name || null\n  }\n}];"
      },
