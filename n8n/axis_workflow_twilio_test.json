      "id": "node_07",
      "name": "07 Supabase: Get History",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        2300,
        500
      ],
      "credentials": {
        "supabaseApi": {
          "id": "supabase_cred",
          "name": "Supabase Config"
        }
