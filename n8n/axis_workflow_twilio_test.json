        },
        "options": {
          "responseFormat": "json_object"
        }
      },
      "id": "node_09",
      "name": "09 OpenAI Native: Axis",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        2700,
        500
      ],
      "credentials": {
        "openAiApi": {
          "id": "openai_cred",
          "name": "OpenAI Config"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "try {\n  let rawContent = $input.first().json.choices[0].message.content;\n  // Limpeza caso a OpenAI cuspa wrappers markdown\n  if (rawContent.startsWith('```json')) {\n    rawContent = rawContent.replace(/^```json/g, '').replace(/```$/g, '').trim();\n  }\n  const data = JSON.parse(rawContent);\n  \n  // Implementação de menu sutil e premium em linguagem natural\n  if (data.sugestoes_elegantes && Array.isArray(data.sugestoes_elegantes) && data.sugestoes_elegantes.length > 0) {\n    let addendum = '\\n\\n';\n    \n    // Fraseologia elegante contextual dependendo da primeira opção para soar mais fluido\n    const fl = data.sugestoes_elegantes[0].toLowerCase();\n    if (fl.includes('comprar')) {\n       addendum += 'Posso te ajudar com:\\n';\n    } else if (fl.includes('agendar')) {\n       addendum += 'Sobre esse imóvel, o que prefere fazer?\\n';\n    } else if (fl.includes('manutenção') || fl.includes('repasse')) {\n       addendum += 'Escolha o serviço desejado:\\n';\n    } else if (fl.includes('continuar com a axis')) {\n       addendum += 'Como prefere seguir?\\n';\n    } else {\n       addendum += 'Como posso te ajudar agora?\\n';\n    }\n\n    data.sugestoes_elegantes.forEach((opc) => {\n       addendum += `- ${opc}\\n`;\n    });\n    \n    addendum += '\\n*(Sinta-se à vontade para responder do seu jeito!)*';\n    \n    data.message_to_user = data.message_to_user + addendum;\n  }\n  \n  return [{ json: data }];\n} catch (e) {\n  throw new Error('Falha ao processar resposta da OpenAI: ' + e.message);\n}"
      },
