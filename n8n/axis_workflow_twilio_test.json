    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Twilio envia dados em x-www-form-urlencoded (ex: Body, From, ProfileName)\nconst rawPhone = body.From || body.phone || '';\nconst phone = rawPhone.replace(/\\D/g, '');\nconst message = (body.Body || body.message || '').trim();\nconst name = body.ProfileName || body.name || null;\nconst channel = 'whatsapp';\n\nconst identifier = phone;\n\nif (!identifier) throw new Error('Campo obrigatório ausente: From/phone');\nif (!message) throw new Error('Campo obrigatório ausente: Body/message');\n\nlet propertyRef = body.property_code || null;\nif (!propertyRef) {\n  const codeMatch = message.match(/\\bREF[-_]?\\d+\\b/i);\n  propertyRef = codeMatch ? codeMatch[0].toUpperCase().replace(/[-_]/g, '') : null;\n}\n\nreturn [{\n  json: {\n    identifier,\n    channel,\n    message,\n    property_ref: propertyRef,\n    name\n  }\n}];"
      },
      "id": "node_02",
      "name": "02 Code: Normaliza Payload Twilio",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        400
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "properties",
        "returnAll": false,
        "limit": 1,
        "filterByFormula": "=property_code.eq.{{ $json.property_ref }}",
        "options": {}
